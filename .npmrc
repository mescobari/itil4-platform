# Forzar instalación de devDependencies aunque NODE_ENV=production.
#
# Razón: Hostinger setea NODE_ENV=production durante el deploy, lo que hace
# que `npm ci` (sin más flags) omita devDependencies. Pero TypeScript, Vite y
# los plugins de build viven en devDependencies — sin ellos `npm run build`
# falla con "tsc: command not found".
#
# production=false fuerza npm a instalar deps + devDeps siempre, sin importar
# NODE_ENV. Esto solo afecta el `npm install` durante deploy; el código
# ejecutándose en runtime sigue respetando NODE_ENV=production.
production=false
