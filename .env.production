# Producción — Vite lee este archivo SOLO cuando ejecutas `npm run build`.
# `npm run dev` sigue leyendo .env (con VITE_API_URL=http://localhost:3001).
#
# Vacío = mismo origen → fetch('/api/...') va contra Express en el dominio
# servido (https://itil4.iq.com.bo). Sin CORS, sin URLs hardcodeadas.
VITE_API_URL=
