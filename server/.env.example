# Backend — copia este archivo a `server/.env` localmente.
# `server/.env` NO se commitea (lleva secretos reales). Este sí (sin secretos).
# En producción (Hostinger) las vars se definen en el panel Node.js App,
# no en archivo.

# ─── App ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Database (MySQL/MariaDB) ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=itil4_app
DB_PASSWORD=cambia_esto_localmente
DB_NAME=itil4_funnel

# ─── Auth (en producción genera valores nuevos: openssl rand -hex 32) ──────
JWT_SECRET=genera-un-string-aleatorio-de-64-chars-aqui
CHALLENGE_SESSION_SECRET=genera-otro-string-aleatorio-distinto-aqui
ADMIN_EMAIL=tu-email-admin@example.com

# ─── Get Code (anti-abuso) ─────────────────────────────────────────────────
STRICT_EMAIL_MATCH=true
TURNSTILE_SECRET=

# ─── Email (SMTP) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=tu_app_password_aqui
EMAIL_FROM="Tu Nombre <tu@gmail.com>"

# ─── Paths (lead magnet PDFs, opcionales) ──────────────────────────────────
SAMPLE_PDF_PATH=./assets/muestra-itil4.pdf
CHECKLIST_PDF_PATH=./assets/checklist-7dias.pdf
GLOSSARY_PDF_PATH=./assets/glosario-itil4.pdf
